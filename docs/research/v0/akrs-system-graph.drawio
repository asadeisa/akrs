        <mxCell id="b1" value="Prompt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="40" y="395" width="160" height="60" as="geometry" /></mxCell>
        <mxCell id="b2" value="Mode Selection&#10;(Mode 0–4)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="280" y="390" width="180" height="70" as="geometry" /></mxCell>
