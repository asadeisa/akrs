<mxfile host="app.diagrams.net" type="device">
  <diagram id="akrs-system" name="AKRS System (reconstructed)">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2060" pageHeight="1260" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===================== ZONE BACKGROUNDS ===================== -->
        <mxCell id="z1" value="LEADER  —  Workflow Generation (plan once)  [Appendix: generation algorithm]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;fontSize=14;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="20" y="80" width="1560" height="210" as="geometry" />
        </mxCell>
        <mxCell id="z2" value="RUNTIME NAVIGATION  —  one route, never random  [Constitution: Navigation]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontStyle=1;fontSize=14;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="20" y="330" width="1560" height="170" as="geometry" />
        </mxCell>
        <mxCell id="z3" value="WORKER  —  Execution (execute many)  [Execution Contract]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;fontStyle=1;fontSize=14;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="20" y="540" width="1560" height="300" as="geometry" />
        </mxCell>
        <mxCell id="zg" value="OPEN GAPS / MYSTERIES&#10;(red = NOT resolved by the 3 docs)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff0f0;strokeColor=#b85450;verticalAlign=top;fontStyle=1;fontSize=13;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1620" y="80" width="400" height="930" as="geometry" />
