        <!-- ===================== LEADER PIPELINE (snake) ===================== -->
        <mxCell id="a1" value="Collect Sources&#10;(reqs, docs, repo, dev)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="40" y="120" width="160" height="55" as="geometry" /></mxCell>
        <mxCell id="a2" value="Analyze Project" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="290" y="120" width="160" height="55" as="geometry" /></mxCell>
        <mxCell id="a3" value="Identify Business&#10;Capabilities" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="540" y="120" width="160" height="55" as="geometry" /></mxCell>
        <mxCell id="a4" value="Generate Plans" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="790" y="120" width="160" height="55" as="geometry" /></mxCell>
        <mxCell id="a5" value="Generate Phases" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="1040" y="120" width="160" height="55" as="geometry" /></mxCell>
        <mxCell id="a6" value="Generate Tasks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="1290" y="120" width="160" height="55" as="geometry" /></mxCell>

        <mxCell id="a7" value="Extract Shared&#10;Knowledge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="40" y="215" width="160" height="55" as="geometry" /></mxCell>
        <mxCell id="a8" value="Generate Memory&#10;(reusable index)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="290" y="215" width="160" height="55" as="geometry" /></mxCell>
        <mxCell id="a9" value="Generate Router&#10;(routes only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="540" y="215" width="160" height="55" as="geometry" /></mxCell>
        <mxCell id="a10" value="Generate Roads&#10;(1 Road per Task)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="790" y="215" width="160" height="55" as="geometry" /></mxCell>
        <mxCell id="a11" value="Validate Workflow&#10;(checklist)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="1040" y="215" width="160" height="55" as="geometry" /></mxCell>
        <mxCell id="a12" value="Workflow Ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1290" y="215" width="160" height="55" as="geometry" /></mxCell>

